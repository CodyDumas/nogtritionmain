          <div style="font-size:16px;font-weight:500;margin-bottom:2px">${s.name}</div>
          ${s.desc ? `<div style="font-size:12px;color:var(--muted);margin-bottom:8px">${s.desc}</div>` : ''}
          <div style="display:flex;gap:10px;margin-top:6px">
            <span style="font-size:12px;color:var(--muted)">${wktCount} workout${wktCount!==1?'s':''}</span>
            <span style="font-size:12px;color:var(--muted)">${exTotal} exercise${exTotal!==1?'s':''}</span>
          </div>
        </div>
        <div style="display:flex;gap:8px;align-items:center;margin-left:10px;flex-shrink:0">
