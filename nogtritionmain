}

// ── WORKOUT-IN-SPLIT CRUD ──
let swktSplitId = null, swktEditId = null;
const MUSCLE_GROUPS = ['Chest','Back','Shoulders','Biceps','Triceps','Legs','Glutes','Core','Cardio','Full Body'];

function openNewWorkoutInSplit() {
  swktSplitId = activeSplitId; swktEditId = null; swktExRows = [];
  document.getElementById('swkt-name-input').value = '';
  document.getElementById('swkt-focus-input').value = '';
  document.getElementById('swkt-split-id').value = swktSplitId;
  document.getElementById('swkt-edit-id').value = '';
  document.getElementById('split-workout-modal-title').textContent = 'New Workout';
  renderSwktExEditor(); openModal('split-workout-modal');
}

function openEditWorkout(splitId, workoutId) {
  swktSplitId=splitId; swktEditId=workoutId;
  const s=(state.splits||[]).find(s=>s.id===splitId);
  const w=s&&(s.workouts||[]).find(w=>w.id===workoutId);
  if(!w) return;
  document.getElementById('swkt-name-input').value=w.name;
  document.getElementById('swkt-focus-input').value=w.focus||'';
  document.getElementById('swkt-split-id').value=splitId;
  document.getElementById('swkt-edit-id').value=workoutId;
  document.getElementById('split-workout-modal-title').textContent='Edit Workout';
  swktExRows=(w.exercises||[]).map(e=>({...e}));
  renderSwktExEditor(); openModal('split-workout-modal');
}

function renderSwktExEditor() {
  const el = document.getElementById('swkt-ex-editor');
  if (!swktExRows.length) { el.innerHTML='<div style="color:var(--muted);font-size:13px;padding:6px 0 10px">No exercises yet \u2014 tap + Add above.</div>'; return; }
  el.innerHTML = swktExRows.map((ex,i)=>`
    <div style="padding:10px 0;border-bottom:1px solid var(--border)">
      <div style="display:flex;gap:8px;align-items:flex-start">
        <div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:6px">
          <input type="text" value="${ex.name||''}" placeholder="Exercise name" oninput="swktExRows[${i}].name=this.value" style="font-size:14px">
          <select onchange="swktExRows[${i}].muscle=this.value" style="font-size:13px">
            ${MUSCLE_GROUPS.map(m=>`<option${ex.muscle===m?' selected':''}>${m}</option>`).join('')}
          </select>
          <div style="display:flex;gap:6px">
            <div style="flex:1"><label style="margin-top:0;font-size:10px">Target Sets</label><input type="number" value="${ex.targetSets||3}" min="1" oninput="swktExRows[${i}].targetSets=+this.value" style="font-size:13px;padding:6px 10px"></div>
            <div style="flex:1"><label style="margin-top:0;font-size:10px">Target Reps</label><input type="number" value="${ex.targetReps||8}" min="1" oninput="swktExRows[${i}].targetReps=+this.value" style="font-size:13px;padding:6px 10px"></div>
          </div>
        </div>
        <button class="del-btn" onclick="removeSwktEx(${i})" style="margin-top:4px">\u2715</button>
      </div>
    </div>`).join('');
}

function addSwktExRow() {
  swktExRows.push({name:'',muscle:'Chest',targetSets:3,targetReps:8});
  renderSwktExEditor();
  const inp=document.querySelectorAll('#swkt-ex-editor input[type="text"]');
  if(inp.length) inp[inp.length-1].focus();
}

function removeSwktEx(i) { swktExRows.splice(i,1); renderSwktExEditor(); }

function saveWorkoutInSplit() {
  const name=document.getElementById('swkt-name-input').value.trim();
  if(!name){showToast('Enter a workout name','error');return;}
  const validEx=swktExRows.filter(e=>e.name.trim());
  const splitId=parseInt(document.getElementById('swkt-split-id').value);
  const editId=parseInt(document.getElementById('swkt-edit-id').value)||null;
  const s=(state.splits||[]).find(s=>s.id===splitId);
  if(!s) return;
  if(!s.workouts) s.workouts=[];
  const wkt={
    id:editId||Date.now(), name,
    focus:document.getElementById('swkt-focus-input').value.trim(),
    exercises:validEx.map(e=>({name:e.name.trim(),muscle:e.muscle,targetSets:e.targetSets||3,targetReps:e.targetReps||8}))
  };
  if(editId){const idx=s.workouts.findIndex(w=>w.id===editId);if(idx>-1)s.workouts[idx]=wkt;else s.workouts.push(wkt);}
  else s.workouts.push(wkt);
  saveState(); closeModal('split-workout-modal'); renderWorkoutsInSplit(s);
  showToast(editId?'Workout updated!':'Workout added! \ud83d\udcaa','success');
}

function deleteWorkoutFromSplit(splitId,workoutId) {
  if(!confirm('Delete this workout?')) return;
  const s=(state.splits||[]).find(s=>s.id===splitId);
  if(s){s.workouts=(s.workouts||[]).filter(w=>w.id!==workoutId);saveState();renderWorkoutsInSplit(s);}
  showToast('Workout deleted');
}

// ── START SESSION ──
function startSessionFromWorkout(splitId,workoutId) {
  const s=(state.splits||[]).find(s=>s.id===splitId);
  const w=s&&(s.workouts||[]).find(w=>w.id===workoutId);
  if(!w) return;
  const d=today();
  state.workoutLog[d]={
    date:d, name:w.name, splitId, workoutId, splitName:s.name,
    exercises:(w.exercises||[]).map(ex=>({name:ex.name,muscle:ex.muscle,targetSets:ex.targetSets,targetReps:ex.targetReps,sets:[]}))
  };
  saveState(); showWktView('today');
  showToast(w.name+' started! Let\'s go \ud83d\udd25','success');
}

function renderSessionPicker() {
  const el=document.getElementById('session-picker-list');
  const splits=state.splits||[];
  if(!splits.length){el.innerHTML='<div style="color:var(--muted);font-size:13px;padding:8px 0">No splits yet \u2014 create one in My Splits.</div>';return;}
  const html=splits.map(s=>{
    const workouts=s.workouts||[];
    if(!workouts.length) return '';
    return `<div style="margin-bottom:12px">
      <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">${s.name}</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        ${workouts.map(w=>`<button class="chip" onclick="startSessionFromWorkout(${s.id},${w.id})">${w.name}</button>`).join('')}
      </div>
    </div>`;
  }).filter(Boolean).join('');
  el.innerHTML=html||'<div style="color:var(--muted);font-size:13px;padding:4px 0">Add workouts to your splits first.</div>';
}

// ── WORKOUT SESSION ────────────────────────────────────────────────────────
function getOrCreateTodayWorkout() {
  const d=today();
  if(!state.workoutLog[d]){state.workoutLog[d]={date:d,name:'Freeform Workout',exercises:[]};saveState();}
  return state.workoutLog[d];
}

function refreshWorkout() {
  const w=getOrCreateTodayWorkout();
  const has=w.exercises.length>0;
  document.getElementById('session-picker-area').style.display=has?'none':'block';
  document.getElementById('session-add-ex-btn').style.display=has?'inline-block':'none';
  const titleEl=document.getElementById('session-title');
  const splitLbl=document.getElementById('session-split-label');
  if(titleEl) titleEl.textContent=has?w.name:'Active Session';
  if(splitLbl) splitLbl.textContent=w.splitName||'';
  const nameEl=document.getElementById('workout-session-name');
  if(nameEl) nameEl.textContent=has?(w.exercises.length+' exercise'+(w.exercises.length!==1?'s':'')):'';
  if(!has){renderSessionPicker();document.getElementById('exercise-list').innerHTML='';return;}

  document.getElementById('exercise-list').innerHTML=w.exercises.map((ex,ei)=>{
    const sets=ex.sets||[];
    const best=getPrevBest(ex.name);
    return `<div class="exercise-card">
      <div class="exercise-header">
        <div style="flex:1;min-width:0">
          <div class="exercise-name">${ex.name}</div>
          <div class="exercise-sets">
            <span style="color:var(--muted)">${ex.muscle}</span>
            ${ex.targetSets?`<span style="color:var(--muted)"> \u00b7 target ${ex.targetSets}\u00d7${ex.targetReps}</span>`:''}
            ${best?`<span style="color:var(--accent)"> \u00b7 best ${best}lbs</span>`:''}
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:6px;flex-shrink:0">
          <button class="btn btn-primary btn-sm" onclick="openAddSet(${ei})">+ Set</button>
          <button class="del-btn" onclick="deleteExercise(${ei})">\u2715</button>
        </div>
      </div>
      ${sets.length?`<table class="sets-table">
        <tr><th>#</th><th>Weight</th><th>Reps</th><th>Details</th><th></th></tr>
        ${sets.map((s,si)=>{
          const typeBadge = s.type === 'warmup'  ? `<span style="background:rgba(255,200,50,0.15);color:#ffcc32;font-size:9px;padding:2px 6px;border-radius:5px;margin-right:4px">WARM</span>`
                          : s.type === 'dropset' ? `<span style="background:rgba(255,80,80,0.15);color:#ff5050;font-size:9px;padding:2px 6px;border-radius:5px;margin-right:4px">DROP</span>`
                          : s.type === 'assisted'? `<span style="background:rgba(130,80,255,0.15);color:#a060ff;font-size:9px;padding:2px 6px;border-radius:5px;margin-right:4px">ASST</span>`
                          : '';
          const dropInfo  = s.type==='dropset' && s.dropWeight ? `<div style="font-size:10px;color:#ff5050">↓${s.dropWeight}lbs×${s.dropReps||'?'}</div>` : '';
          const asstInfo  = s.type==='assisted' && s.assistedReps ? `<div style="font-size:10px;color:#a060ff">+${s.assistedReps} assisted</div>` : '';
          const rirInfo   = s.rir !== null && s.rir !== undefined ? `<span style="font-size:10px;color:var(--muted)">RIR ${s.rir}</span>` : '';
          const noteInfo  = s.notes ? `<span style="font-size:10px;color:var(--muted);margin-left:4px">${s.notes}</span>` : '';
          return `<tr>
            <td style="color:var(--muted)">${si+1}</td>
            <td class="${s.type==='warmup'?'':'set-done'}" style="${s.type==='warmup'?'color:var(--muted)':''}"> ${s.weight}lbs</td>
            <td>${s.reps}</td>
            <td style="min-width:80px">${typeBadge}${rirInfo}${noteInfo}${dropInfo}${asstInfo}</td>
            <td><button class="del-btn" onclick="deleteSet(${ei},${si})">\u2715</button></td>
          </tr>`;
        }).join('')}
      </table>`:`<div style="padding:8px 12px;font-size:12px;color:var(--muted)">No sets yet \u2014 tap + Set to log.</div>`}
    </div>`;
  }).join('');
}

function getPrevBest(exName) {
  const name=exName.toLowerCase(); let best=0; const todayStr=today();
  Object.entries(state.workoutLog||{}).forEach(([date,w])=>{
    if(date===todayStr) return;
    (w.exercises||[]).forEach(ex=>{
      if(ex.name.toLowerCase()===name)(ex.sets||[]).forEach(s=>{if((s.weight||0)>best)best=s.weight;});
    });
  });
  return best>0?best:null;
}

function openAddExercise(){openModal('add-exercise-modal');}
function addExercise(){
  const name=document.getElementById('ex-name').value.trim();
  if(!name){showToast('Enter exercise name','error');return;}
  const w=getOrCreateTodayWorkout();
  w.exercises.push({name,muscle:document.getElementById('ex-muscle').value,sets:[]});
  saveState(); document.getElementById('ex-name').value='';
  closeModal('add-exercise-modal'); refreshWorkout();
  showToast('Exercise added!','success');
}

function deleteExercise(ei){const w=getOrCreateTodayWorkout();w.exercises.splice(ei,1);saveState();refreshWorkout();}

let currentSetType = 'normal';
let currentRIR = null;

function selectSetType(type, el) {
  currentSetType = type;
  document.querySelectorAll('#set-type-chips .chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('assisted-section').style.display = type === 'assisted' ? 'block' : 'none';
  document.getElementById('dropset-section').style.display  = type === 'dropset'  ? 'block' : 'none';
}

function selectRIR(val, el) {
  currentRIR = val;
  document.querySelectorAll('#rir-chips .chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('rir-label').textContent = val === null ? 'Not set' : val === 0 ? 'Failure / 0 left' : val + ' rep' + (val !== 1 ? 's' : '') + ' left in tank';
}

function openAddSet(ei) {
  currentExerciseIndex = ei;
  currentSetType = 'normal';
  currentRIR = null;
  const ex = getOrCreateTodayWorkout().exercises[ei];
  document.getElementById('add-set-title').textContent = ex.name;
  document.getElementById('set-weight').value = '';
  document.getElementById('set-reps').value = ex.targetReps || '';
  document.getElementById('set-notes').value = '';
  document.getElementById('set-assisted-reps').value = '';
  document.getElementById('set-drop-weight').value = '';
