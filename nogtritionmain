  currentRecipeIngredients.push({
    savedFoodId, name: food.name, servings: 1,
    cal: food.cal, protein: food.protein, carbs: food.carbs, fat: food.fat
  });
  closeModal('pick-ingredient-modal');
  renderRecipeIngredients();
