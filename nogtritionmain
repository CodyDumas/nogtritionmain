}

function calcRecipeTotals(recipe) {
  return (recipe.ingredients||[]).reduce((acc, ing) => {
    const s = ing.servings || 1;
    acc.cal += (ing.cal||0)*s;
    acc.protein += (ing.protein||0)*s;
    acc.carbs += (ing.carbs||0)*s;
    acc.fat += (ing.fat||0)*s;
    return acc;
  }, { cal:0, protein:0, carbs:0, fat:0 });
}

