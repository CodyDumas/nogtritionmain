    sfList.innerHTML = savedFoods.map(f => `
      <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)">
        <div style="flex:1;min-width:0">
          <div style="font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${f.name}</div>
          <div style="font-size:11px;color:var(--muted);margin-top:2px">${Math.round(f.cal)} kcal · P:${(f.protein||0).toFixed(1)}g C:${(f.carbs||0).toFixed(1)}g F:${(f.fat||0).toFixed(1)}g</div>
        </div>
        <div style="display:flex;gap:6px;margin-left:10px;flex-shrink:0">
