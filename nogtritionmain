  state.foodLog[d].push({
    id: Date.now(), name: food.name, meal: getMealFromTime(),
    cal: food.cal, protein: food.protein, carbs: food.carbs, fat: food.fat,
    sodium: food.sodium||0, fiber: food.fiber||0, sugar: food.sugar||0,
    calcium:0, iron:0, potassium:0, vitc:0, vitd:0, chol:0, satfat:0,
    time: new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})
  });
  saveState(); refreshDashboard();
  showToast(food.name + ' logged! 🍽️', 'success');
}

function deleteSavedFood(id) {
  state.savedFoods = (state.savedFoods||[]).filter(f => f.id !== id);
  saveState(); renderRecipeBook();
  showToast('Removed from saved foods');
}

