let progExChartInst = null, progVolChartInst = null, progSessChartInst = null, progMuscleChartInst = null;
let currentProgMetric = 'maxWeight';

const CHART_COLORS = ['#3b9eff','#7dc4ff','#a0cfff','#c8e4ff','#1a6bbf','#5eb3ff','#0a4a8a','#d0eaff'];

const METRIC_LABELS = {
  maxWeight:   'Max weight used per session (lbs)',
  totalVolume: 'Total volume per session (sets × reps × lbs)',
  maxReps:     'Max reps in a single set per session',
  sets:        'Number of sets per session'
};

function buildExerciseData() {
  // Returns { exerciseName: { dates:[], maxWeight:[], totalVolume:[], maxReps:[], sets:[], muscle } }
  const map = {};
  Object.entries(state.workoutLog).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([date, w]) => {
    (w.exercises||[]).forEach(ex => {
      const key = ex.name.trim().toLowerCase();
      if (!map[key]) map[key] = { name: ex.name, muscle: ex.muscle, dates:[], maxWeight:[], totalVolume:[], maxReps:[], sets:[] };
      const sets = ex.sets || [];
      if (!sets.length) return;
      map[key].dates.push(date.slice(5));   // MM-DD
      map[key].maxWeight.push(Math.max(...sets.map(s=>s.weight||0)));
      map[key].totalVolume.push(sets.reduce((sum,s)=>(sum+(s.weight||0)*(s.reps||0)),0));
      map[key].maxReps.push(Math.max(...sets.map(s=>s.reps||0)));
      map[key].sets.push(sets.length);
    });
  });
  return map;
}

function refreshProgress() {
  const exData = buildExerciseData();
  const allWorkouts = Object.values(state.workoutLog);
  const totalSessions = allWorkouts.length;
  const totalSets = allWorkouts.reduce((s,w)=>(s+(w.exercises||[]).reduce((es,e)=>(es+(e.sets||[]).length),0)),0);
  const totalVol = allWorkouts.reduce((s,w)=>(s+(w.exercises||[]).reduce((es,e)=>(es+(e.sets||[]).reduce((ss,set)=>(ss+(set.weight||0)*(set.reps||0)),0)),0)),0);
  const exerciseCount = Object.keys(exData).length;

  document.getElementById('prog-total-sessions').textContent = totalSessions;
  document.getElementById('prog-total-sets').textContent = totalSets;
  document.getElementById('prog-total-vol').textContent = totalVol >= 1000 ? (totalVol/1000).toFixed(1)+'k' : Math.round(totalVol);
  document.getElementById('prog-exercises-count').textContent = exerciseCount;

  // Populate exercise dropdown
  const sel = document.getElementById('prog-exercise-select');
  const prevVal = sel.value;
  sel.innerHTML = '<option value="">— Select an exercise —</option>';
  Object.entries(exData).sort((a,b)=>a[1].name.localeCompare(b[1].name)).forEach(([key, ex]) => {
    const opt = document.createElement('option');
    opt.value = key;
    opt.textContent = ex.name + ' (' + ex.muscle + ')';
    sel.appendChild(opt);
  });
  if (prevVal) sel.value = prevVal;

  renderExerciseChart();
  renderVolumeChart(allWorkouts);
  renderSessionsChart(allWorkouts);
  renderMuscleChart(allWorkouts);
  renderPRList(exData);
}

