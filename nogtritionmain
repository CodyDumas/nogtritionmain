let activeSplitId = null;
let swktExRows = [];

// ── VIEW SWITCHING ──
function showWktView(view) {
  document.getElementById('wkt-splits-view').style.display = view === 'splits' ? 'block' : 'none';
  document.getElementById('wkt-today-view').style.display  = view === 'today'  ? 'block' : 'none';
  document.getElementById('wkt-view-splits').classList.toggle('active', view === 'splits');
  document.getElementById('wkt-view-today').classList.toggle('active',  view === 'today');
  if (view === 'splits') navSplits();
  if (view === 'today')  { renderSessionPicker(); refreshWorkout(); }
}

// ── SPLITS LIST ──
function navSplits() {
  document.getElementById('wkt-bc-splits').style.display = 'block';
  document.getElementById('wkt-bc-workouts').style.display = 'none';
  activeSplitId = null;
  renderSplitsList();
}

function renderSplitsList() {
  const el = document.getElementById('splits-list');
  const splits = state.splits || [];
  if (!splits.length) {
    el.innerHTML = '<div style="color:var(--muted);font-size:14px;padding:8px 0">No splits yet. Tap + New Split to get started.</div>';
    return;
  }
  el.innerHTML = splits.map(s => {
    const wktCount = (s.workouts||[]).length;
    const exTotal  = (s.workouts||[]).reduce((n,w)=>(n+(w.exercises||[]).length),0);
    return `<div class="card" style="cursor:pointer;margin-bottom:10px" onclick="openSplitWorkouts(${s.id})">
