<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#000000">
<title>NOGTRITION</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #000000;
    --surface: #0d0d0d;
    --surface2: #1a1a1a;
    --border: #1e2a3a;
    --accent: #3b9eff;
    --accent2: #ff4747;
    --text: #ffffff;
    --muted: #6b7a8d;
    --green: #3b9eff;
    --blue: #7dc4ff;
    --orange: #a0cfff;
    --radius: 14px;
    --tab-h: 72px;
    --header-h: 58px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html, body { height: 100%; overflow: hidden; background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; }
  
  /* LAYOUT */
  #app { display: flex; flex-direction: column; height: 100vh; height: 100dvh; }
  #header { height: var(--header-h); background: var(--bg); border-bottom: 1px solid var(--border); display: flex; align-items: center; padding: 0 16px; gap: 12px; position: relative; z-index: 10; flex-shrink: 0; }
  #header h1 { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 2px; color: var(--accent); flex: 1; }
  #header .date { font-size: 12px; color: var(--muted); }
  .sync-btn { background: none; border: 1px solid var(--border); color: var(--muted); font-size: 11px; padding: 5px 10px; border-radius: 8px; cursor: pointer; font-family: 'DM Sans', sans-serif; }
  .sync-btn:active { background: var(--surface2); }

  #pages { flex: 1; overflow: hidden; position: relative; }
  .page { position: absolute; inset: 0; overflow-y: auto; overflow-x: hidden; padding: 16px 16px calc(var(--tab-h) + 16px); display: none; -webkit-overflow-scrolling: touch; }
  .page.active { display: block; }
  
  #tabs { height: var(--tab-h); background: var(--surface); border-top: 1px solid var(--border); display: flex; align-items: stretch; flex-shrink: 0; }
  .tab { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; cursor: pointer; background: none; border: none; color: var(--muted); font-family: 'DM Sans', sans-serif; font-size: 10px; transition: color 0.15s; padding-bottom: 6px; }

  /* SUB-TABS */
  .sub-tab-bar { display: flex; background: var(--surface2); border-radius: 12px; padding: 3px; margin-bottom: 18px; gap: 3px; }
  .sub-tab { flex: 1; padding: 9px; border-radius: 9px; border: none; background: transparent; color: var(--muted); font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.15s; }
  .sub-tab.active { background: var(--accent); color: #ffffff; font-weight: 600; }
  .tab svg { width: 22px; height: 22px; stroke-width: 1.8; }
  .tab.active { color: var(--accent); }

  /* CARDS */
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin-bottom: 12px; }
  .card-title { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 12px; }
  
  /* STATS ROW */
  .stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
  .stat-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px; text-align: center; }
  .stat-val { font-family: 'Bebas Neue', sans-serif; font-size: 32px; color: var(--accent); line-height: 1; }
  .stat-label { font-size: 10px; color: var(--muted); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }

  /* INPUTS */
  input, select, textarea { background: var(--surface2); border: 1px solid var(--border); color: var(--text); border-radius: 10px; padding: 11px 14px; font-family: 'DM Sans', sans-serif; font-size: 15px; width: 100%; outline: none; }
  input:focus, select:focus { border-color: var(--accent); }
  select option { background: var(--surface2); }
  label { font-size: 12px; color: var(--muted); display: block; margin-bottom: 6px; margin-top: 12px; }

  /* BUTTONS */
  .btn { display: block; width: 100%; padding: 14px; border-radius: 12px; border: none; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 600; cursor: pointer; text-align: center; transition: transform 0.1s, opacity 0.1s; }
  .btn:active { transform: scale(0.97); }
  .btn-primary { background: var(--accent); color: #ffffff; }
  .btn-secondary { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
  .btn-danger { background: transparent; color: var(--accent2); border: 1px solid var(--accent2); }
  .btn-sm { padding: 8px 14px; font-size: 13px; width: auto; display: inline-block; }

  /* SECTION TITLE */
  .section-title { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 1px; margin-bottom: 14px; color: var(--text); }

  /* WORKOUT */
  .exercise-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 10px; overflow: hidden; }
  .exercise-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; cursor: pointer; }
  .exercise-name { font-weight: 500; font-size: 16px; }
  .exercise-sets { font-size: 12px; color: var(--muted); }
  .sets-table { width: 100%; border-collapse: collapse; }
  .sets-table th { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--muted); padding: 8px 12px; text-align: left; border-top: 1px solid var(--border); }
  .sets-table td { padding: 9px 12px; font-size: 14px; border-top: 1px solid var(--border); }
  .sets-table tr:last-child td { border-bottom: none; }
  .set-done { color: var(--green); }
  .del-btn { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 16px; padding: 4px 8px; }

  /* MACROS BAR */
  .macro-bar { height: 8px; border-radius: 4px; background: var(--surface2); overflow: hidden; margin: 8px 0 4px; }
  .macro-fill { height: 100%; border-radius: 4px; transition: width 0.4s; }
  .macro-row { display: flex; justify-content: space-between; margin-bottom: 10px; }
  .macro-item { text-align: center; flex: 1; }
  .macro-val { font-weight: 600; font-size: 16px; }
  .macro-name { font-size: 10px; color: var(--muted); }

  /* FOOD LOG */
  .food-item { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .food-item:last-child { border-bottom: none; }
  .food-name { font-size: 14px; font-weight: 500; }
  .food-cals { font-family: 'Bebas Neue', sans-serif; font-size: 20px; color: var(--accent); }
  .food-detail { font-size: 11px; color: var(--muted); margin-top: 1px; }

  /* WEIGHT CHART */
  .weight-chart { width: 100%; height: 140px; }

  /* REST TIMER */
  #rest-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 100; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; display: none; }
  #rest-overlay.show { display: flex; }
  .timer-ring { position: relative; width: 200px; height: 200px; }
  .timer-ring svg { position: absolute; inset: 0; transform: rotate(-90deg); }
  .timer-ring-center { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .timer-time { font-family: 'Bebas Neue', sans-serif; font-size: 64px; color: var(--accent); letter-spacing: 2px; }
  .timer-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }

  /* PROFILE / WEIGHT */
  .weight-entry { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); }
  .weight-date { font-size: 12px; color: var(--muted); }
  .weight-val { font-family: 'Bebas Neue', sans-serif; font-size: 24px; color: var(--blue); }

  /* MODAL */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 50; display: none; align-items: flex-end; }
  .modal-overlay.show { display: flex; }
  .modal { background: var(--surface); border-radius: 20px 20px 0 0; padding: 20px; width: 100%; max-height: 85vh; overflow-y: auto; border-top: 1px solid var(--border); }
  .modal-title { font-family: 'Bebas Neue', sans-serif; font-size: 24px; margin-bottom: 16px; }
  .modal-close { float: right; background: var(--surface2); border: none; color: var(--muted); font-size: 18px; width: 30px; height: 30px; border-radius: 50%; cursor: pointer; }

  /* MICRO TABLE */
  .micro-table { width: 100%; font-size: 13px; }
  .micro-table tr td:first-child { color: var(--muted); padding: 5px 0; }
  .micro-table tr td:last-child { text-align: right; font-weight: 500; }

  /* BARCODE */
  #barcode-area { background: var(--surface2); border-radius: var(--radius); padding: 20px; text-align: center; border: 1.5px dashed var(--border); }
  .scan-icon { font-size: 48px; margin-bottom: 8px; }

  /* SETTINGS */
  .setting-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid var(--border); }
  .setting-label { font-size: 14px; }
  .setting-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .setting-val { font-size: 14px; color: var(--accent); font-weight: 500; }
  
  /* TOGGLE */
  .toggle { position: relative; width: 46px; height: 26px; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-slider { position: absolute; cursor: pointer; inset: 0; background: var(--surface2); border-radius: 13px; transition: 0.2s; border: 1px solid var(--border); }
  .toggle input:checked + .toggle-slider { background: var(--accent); border-color: var(--accent); }
  .toggle-slider:before { content: ''; position: absolute; height: 18px; width: 18px; left: 3px; bottom: 3px; background: white; border-radius: 50%; transition: 0.2s; }
  .toggle input:checked + .toggle-slider:before { transform: translateX(20px); }

  /* CHIPS */
  .chip-row { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0; }
  .chip { padding: 6px 14px; border-radius: 20px; border: 1px solid var(--border); font-size: 13px; cursor: pointer; background: var(--surface2); color: var(--text); }
  .chip.active { background: var(--accent); color: #ffffff; border-color: var(--accent); font-weight: 600; }

  /* TOAST */
  #toast { position: fixed; bottom: calc(var(--tab-h) + 16px); left: 50%; transform: translateX(-50%) translateY(20px); background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 10px 18px; font-size: 13px; z-index: 200; opacity: 0; transition: opacity 0.2s, transform 0.2s; pointer-events: none; white-space: nowrap; }
  #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  #toast.success { border-color: var(--green); color: var(--green); }
  #toast.error { border-color: var(--accent2); color: var(--accent2); }

  /* PROGRESS RING */
  .calorie-ring-wrap { display: flex; align-items: center; justify-content: center; padding: 10px 0 4px; }
  .calorie-ring { position: relative; width: 160px; height: 160px; }
  .calorie-ring svg { transform: rotate(-90deg); }
  .calorie-ring-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .cal-remaining { font-family: 'Bebas Neue', sans-serif; font-size: 40px; line-height: 1; }
  .cal-remaining-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }

  /* MEAL SECTIONS */
  .meal-section { margin-bottom: 4px; }
  .meal-header { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; cursor: pointer; }
  .meal-name { font-weight: 500; font-size: 14px; }
  .meal-kcal { font-size: 13px; color: var(--muted); }
  .meal-body { border-top: 1px solid var(--border); }

  .tag { display: inline-block; padding: 2px 8px; border-radius: 6px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-left: 6px; }
  .tag-green { background: rgba(59,158,255,0.12); color: var(--accent); }
  .tag-blue { background: rgba(125,196,255,0.12); color: var(--blue); }
  .tag-orange { background: rgba(160,207,255,0.12); color: var(--orange); }
  
  .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .input-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
  
  .divider { height: 1px; background: var(--border); margin: 16px 0; }

  /* scrollbar */
  ::-webkit-scrollbar { width: 0px; }
</style>
</head>
<body>

<div id="app">
  <div id="header">
    <h1>NOGTRITION</h1>
    <span class="date" id="header-date"></span>
    <button class="sync-btn" onclick="syncToSheets()">⚡ Sync</button>
  </div>

  <div id="pages">
    <!-- DASHBOARD -->
    <div class="page active" id="page-dashboard">
      <div class="section-title">Today's Overview</div>

      <div class="calorie-ring-wrap">
        <div class="calorie-ring">
          <svg width="160" height="160" viewBox="0 0 160 160">
            <circle cx="80" cy="80" r="68" fill="none" stroke="#1e1e1e" stroke-width="12"/>
            <circle id="cal-ring" cx="80" cy="80" r="68" fill="none" stroke="#3b9eff" stroke-width="12" stroke-linecap="round"
              stroke-dasharray="427" stroke-dashoffset="427" style="transition:stroke-dashoffset 0.6s"/>
          </svg>
          <div class="calorie-ring-center">
            <div class="cal-remaining" id="cal-remaining-num">0</div>
            <div class="cal-remaining-label">kcal left</div>
          </div>
        </div>
      </div>

      <div class="stats-row">
        <div class="stat-box">
          <div class="stat-val" id="dash-consumed">0</div>
          <div class="stat-label">Consumed kcal</div>
        </div>
        <div class="stat-box">
          <div class="stat-val" id="dash-goal">2500</div>
          <div class="stat-label">Goal kcal</div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Macros</div>
        <div class="macro-row">
          <div class="macro-item">
            <div class="macro-val" style="color:var(--blue)" id="dash-protein">0g</div>
            <div class="macro-name">Protein</div>
          </div>
          <div class="macro-item">
            <div class="macro-val" style="color:var(--orange)" id="dash-carbs">0g</div>
            <div class="macro-name">Carbs</div>
          </div>
          <div class="macro-item">
            <div class="macro-val" style="color:var(--accent)" id="dash-fat">0g</div>
            <div class="macro-name">Fat</div>
          </div>
        </div>
        <div class="macro-bar"><div class="macro-fill" id="bar-protein" style="background:var(--blue);width:0%"></div></div>
        <div style="font-size:10px;color:var(--muted);text-align:right" id="bar-protein-label">0 / 180g</div>
        <div class="macro-bar"><div class="macro-fill" id="bar-carbs" style="background:var(--orange);width:0%"></div></div>
        <div style="font-size:10px;color:var(--muted);text-align:right" id="bar-carbs-label">0 / 250g</div>
        <div class="macro-bar"><div class="macro-fill" id="bar-fat" style="background:var(--accent);width:0%"></div></div>
        <div style="font-size:10px;color:var(--muted);text-align:right" id="bar-fat-label">0 / 70g</div>
      </div>

      <div class="card">
        <div class="card-title">Today's Workout</div>
        <div id="dash-workout-summary" style="color:var(--muted);font-size:14px">No workout logged today. Head to the Workout tab!</div>
      </div>

      <div class="card">
        <div class="card-title">Weight Trend</div>
        <canvas class="weight-chart" id="mini-weight-chart"></canvas>
        <div style="text-align:center;font-size:11px;color:var(--muted);margin-top:4px">Last 14 days</div>
      </div>
    </div>

    <!-- NUTRITION + RECIPES (combined) -->
    <div class="page" id="page-nutrition">

      <!-- Sub-tab bar -->
      <div class="sub-tab-bar">
        <button class="sub-tab active" id="sub-nut" onclick="switchSubTab('nut',this)">Nutrition</button>
        <button class="sub-tab" id="sub-rec" onclick="switchSubTab('rec',this)">Recipe Book</button>
      </div>

      <!-- ── NUTRITION PANEL ── -->
      <div id="panel-nut">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
          <div class="section-title" style="margin:0">Nutrition</div>
          <button class="btn btn-primary btn-sm" id="nut-add-btn" onclick="openAddFood()">+ Add Food</button>
        </div>

        <!-- Day of week selector -->
        <div style="margin-bottom:14px">
          <div id="nut-day-strip" style="display:flex;gap:6px;overflow-x:auto;padding-bottom:4px;-webkit-overflow-scrolling:touch;scrollbar-width:none"></div>
          <div id="nut-selected-date" style="font-size:12px;color:var(--muted);margin-top:8px;text-align:center"></div>
        </div>

        <div class="stats-row">
          <div class="stat-box">
            <div class="stat-val" id="nut-consumed">0</div>
            <div class="stat-label">Calories Consumed</div>
          </div>
          <div class="stat-box">
            <div class="stat-val" style="color:var(--accent)" id="nut-remaining">2500</div>
            <div class="stat-label">Calories Left</div>
          </div>
        </div>

        <!-- Macros breakdown -->
        <div class="card" style="padding:14px 16px">
          <div class="card-title">Macros</div>
          <div style="display:flex;justify-content:space-between;margin-bottom:12px">
            <div style="text-align:center;flex:1">
              <div style="font-family:'Bebas Neue',sans-serif;font-size:26px;color:#7dc4ff;line-height:1" id="nut-protein-val">0g</div>
              <div style="font-size:10px;color:var(--muted);margin-top:2px">Protein</div>
            </div>
            <div style="text-align:center;flex:1">
              <div style="font-family:'Bebas Neue',sans-serif;font-size:26px;color:#a0cfff;line-height:1" id="nut-carbs-val">0g</div>
              <div style="font-size:10px;color:var(--muted);margin-top:2px">Carbs</div>
            </div>
            <div style="text-align:center;flex:1">
              <div style="font-family:'Bebas Neue',sans-serif;font-size:26px;color:#ffffff;line-height:1" id="nut-fat-val">0g</div>
              <div style="font-size:10px;color:var(--muted);margin-top:2px">Fat</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
            <div style="font-size:11px;color:#7dc4ff;width:46px">Protein</div>
            <div style="flex:1;height:7px;border-radius:4px;background:var(--surface2);overflow:hidden">
              <div id="nut-bar-protein" style="height:100%;border-radius:4px;background:#7dc4ff;width:0%;transition:width 0.4s"></div>
            </div>
            <div style="font-size:10px;color:var(--muted);min-width:56px;text-align:right" id="nut-bar-protein-lbl">0 / 180g</div>
          </div>
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
            <div style="font-size:11px;color:#a0cfff;width:46px">Carbs</div>
            <div style="flex:1;height:7px;border-radius:4px;background:var(--surface2);overflow:hidden">
              <div id="nut-bar-carbs" style="height:100%;border-radius:4px;background:#a0cfff;width:0%;transition:width 0.4s"></div>
            </div>
            <div style="font-size:10px;color:var(--muted);min-width:56px;text-align:right" id="nut-bar-carbs-lbl">0 / 250g</div>
          </div>
          <div style="display:flex;align-items:center;gap:8px">
            <div style="font-size:11px;color:#ffffff;width:46px">Fat</div>
            <div style="flex:1;height:7px;border-radius:4px;background:var(--surface2);overflow:hidden">
              <div id="nut-bar-fat" style="height:100%;border-radius:4px;background:#ffffff;width:0%;transition:width 0.4s"></div>
            </div>
            <div style="font-size:10px;color:var(--muted);min-width:56px;text-align:right" id="nut-bar-fat-lbl">0 / 70g</div>
          </div>
        </div>

        <div class="card" id="meals-card">
          <div class="card-title" id="nut-log-title">Food Log</div>
          <div id="food-log-list">
            <div style="color:var(--muted);font-size:14px;padding:8px 0">No foods logged yet.</div>
          </div>
        </div>

        <div class="card">
          <div class="card-title">Micronutrients</div>
          <table class="micro-table" id="micro-table">
            <tr><td>Sodium</td><td id="mic-sodium">0 mg</td></tr>
            <tr><td>Fiber</td><td id="mic-fiber">0 g</td></tr>
            <tr><td>Sugar</td><td id="mic-sugar">0 g</td></tr>
            <tr><td>Calcium</td><td id="mic-calcium">0 mg</td></tr>
            <tr><td>Iron</td><td id="mic-iron">0 mg</td></tr>
            <tr><td>Potassium</td><td id="mic-potassium">0 mg</td></tr>
            <tr><td>Vitamin C</td><td id="mic-vitc">0 mg</td></tr>
            <tr><td>Vitamin D</td><td id="mic-vitd">0 IU</td></tr>
            <tr><td>Cholesterol</td><td id="mic-chol">0 mg</td></tr>
            <tr><td>Saturated Fat</td><td id="mic-satfat">0 g</td></tr>
          </table>
        </div>
      </div>

      <!-- ── RECIPE BOOK PANEL ── -->
      <div id="panel-rec" style="display:none">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          <div class="section-title" style="margin:0">Recipe Book</div>
          <button class="btn btn-primary btn-sm" onclick="openNewRecipeModal()">+ New Recipe</button>
        </div>

        <div style="margin-bottom:12px;position:relative">
          <input type="text" id="recipe-search" placeholder="Search recipes & saved foods..." oninput="filterRecipes(this.value)" style="padding-left:38px">
          <span style="position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:15px;pointer-events:none">🔍</span>
        </div>

        <div class="chip-row" style="margin-bottom:14px" id="recipe-filter-chips">
          <div class="chip active" onclick="setRecipeFilter('all',this)">All</div>
