function saveRecipe() {
  const name = document.getElementById('recipe-name-input').value.trim();
  if (!name) { showToast('Enter a recipe name','error'); return; }
  if (!currentRecipeIngredients.length) { showToast('Add at least one ingredient','error'); return; }

  const editId = parseInt(document.getElementById('recipe-edit-id').value) || null;
  const recipe = {
    id: editId || Date.now(),
    name,
    category: document.getElementById('recipe-category-input').value,
    notes: document.getElementById('recipe-notes-input').value.trim(),
    ingredients: JSON.parse(JSON.stringify(currentRecipeIngredients)),
    createdAt: editId ? ((state.recipes||[]).find(r=>r.id===editId)||{}).createdAt || today() : today()
  };

  if (!state.recipes) state.recipes = [];
  if (editId) {
    const idx = state.recipes.findIndex(r => r.id === editId);
    if (idx > -1) state.recipes[idx] = recipe; else state.recipes.push(recipe);
  } else {
    state.recipes.push(recipe);
  }

  saveState();
  closeModal('new-recipe-modal');
  refreshRecipes();
  showToast((editId ? 'Recipe updated!' : 'Recipe saved! 📖'), 'success');
}

// ── RECIPE DETAIL ───────────────────────────────────────────────────────────
function openRecipeDetail(id) {
  const r = (state.recipes||[]).find(r => r.id === id);
  if (!r) return;
  viewingRecipeId = id;

  document.getElementById('detail-recipe-name').textContent = r.name;
  document.getElementById('detail-recipe-meta').textContent = r.category + ' · ' + (r.ingredients||[]).length + ' ingredient(s) · Added ' + r.createdAt;

  const t = calcRecipeTotals(r);
  document.getElementById('detail-cal').textContent = Math.round(t.cal);
  document.getElementById('detail-protein').textContent = t.protein.toFixed(0)+'g';
  document.getElementById('detail-carbs').textContent = t.carbs.toFixed(0)+'g';
  document.getElementById('detail-fat').textContent = t.fat.toFixed(0)+'g';

  document.getElementById('detail-ingredients').innerHTML = (r.ingredients||[]).map(ing => {
    const s = ing.servings||1;
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)">
      <div>
        <div style="font-size:14px;font-weight:500">${ing.name}</div>
        <div style="font-size:11px;color:var(--muted)">×${s} serving${s!==1?'s':''}</div>
      </div>
      <div style="text-align:right;font-size:13px;color:var(--muted)">${Math.round((ing.cal||0)*s)} kcal</div>
    </div>`;
  }).join('');

  const notesWrap = document.getElementById('detail-notes-wrap');
  if (r.notes) {
    notesWrap.style.display = 'block';
    document.getElementById('detail-notes').textContent = r.notes;
  } else {
    notesWrap.style.display = 'none';
  }

  openModal('recipe-detail-modal');
}

function editRecipeFromDetail() {
  closeModal('recipe-detail-modal');
  setTimeout(() => openNewRecipeModal(viewingRecipeId), 200);
}

function deleteRecipeFromDetail() {
  if (!confirm('Delete this recipe?')) return;
  state.recipes = (state.recipes||[]).filter(r => r.id !== viewingRecipeId);
  saveState();
  closeModal('recipe-detail-modal');
  refreshRecipes();
  showToast('Recipe deleted');
}

function logRecipeToday() {
  const r = (state.recipes||[]).find(r => r.id === viewingRecipeId);
  if (!r) return;
  const t = calcRecipeTotals(r);
  const d = today();
  if (!state.foodLog[d]) state.foodLog[d] = [];
  state.foodLog[d].push({
    id: Date.now(), name: r.name + ' (recipe)', meal: getMealFromTime(),
    cal: t.cal, protein: t.protein, carbs: t.carbs, fat: t.fat,
    sodium:0, fiber:0, sugar:0, calcium:0, iron:0, potassium:0, vitc:0, vitd:0, chol:0, satfat:0,
    time: new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})
  });
  saveState();
  closeModal('recipe-detail-modal');
  refreshDashboard();
  showToast(r.name + ' logged to today! 🍽️', 'success');
}

// ── INIT ───────────────────────────────────────────────────────────────────
refreshDashboard();
</script>
