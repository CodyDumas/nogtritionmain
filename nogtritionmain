<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
// ── STATE ──────────────────────────────────────────────────────────────────
const today = () => new Date().toISOString().slice(0,10);

function loadState() {
  try { return JSON.parse(localStorage.getItem('ironlog_state') || '{}'); } catch { return {}; }
}
function saveState() {
  localStorage.setItem('ironlog_state', JSON.stringify(state));
}

let state = loadState();
if (!state.goals) state.goals = { calories: 2500, protein: 180, carbs: 250, fat: 70 };
if (!state.foodLog) state.foodLog = {};
if (!state.workoutLog) state.workoutLog = {};
if (!state.weightLog) state.weightLog = [];
if (!state.sheets) state.sheets = { id: '', key: '' };
if (!state.activeExerciseIndex) state.activeExerciseIndex = null;
if (!state.recipes) state.recipes = [];
if (!state.savedFoods) state.savedFoods = [];
if (!state.splits) state.splits = [];

// ── NAV ────────────────────────────────────────────────────────────────────
// Track active sub-tab per page so switching back restores state
const subTabState = { nutrition: 'nut', workout: 'wkt' };

function switchSubTab(panel, el) {
  const page = el.closest('.page').id.replace('page-','');
  subTabState[page] = panel;

  // Hide all panels in this page, show the target
  el.closest('.page').querySelectorAll('[id^="panel-"]').forEach(p => p.style.display = 'none');
  document.getElementById('panel-' + panel).style.display = 'block';

  // Update sub-tab button states
  el.closest('.sub-tab-bar').querySelectorAll('.sub-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');

  // Trigger refresh for the panel being shown
  if (panel === 'nut') { selectedNutDate = today(); buildDayStrip(); refreshNutrition(); }
  if (panel === 'rec') refreshRecipes();
}

function navTo(page, tabEl) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  tabEl.classList.add('active');

  if (page === 'dashboard') refreshDashboard();
  if (page === 'nutrition') {
    const active = subTabState['nutrition'] || 'nut';
    const bar = document.querySelector('#page-nutrition .sub-tab-bar');
    document.querySelectorAll('#page-nutrition [id^="panel-"]').forEach(p => p.style.display = 'none');
    document.getElementById('panel-' + active).style.display = 'block';
    bar.querySelectorAll('.sub-tab').forEach(t => t.classList.toggle('active', t.id === 'sub-' + active));
    if (active === 'nut') { selectedNutDate = today(); buildDayStrip(); refreshNutrition(); }
    else refreshRecipes();
  }
  if (page === 'workout') { showWktView('splits'); refreshProgress(); }
  if (page === 'weight') refreshWeight();
  if (page === 'settings') loadSettings();
}

// ── DATE ───────────────────────────────────────────────────────────────────
const dateEl = document.getElementById('header-date');
const now = new Date();
dateEl.textContent = now.toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });

// ── TOAST ──────────────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'show ' + type;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.className = '', 2500);
}

// ── MODALS ─────────────────────────────────────────────────────────────────
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
function openModal(id) { document.getElementById(id).classList.add('show'); }

// ── FOOD / NUTRITION ───────────────────────────────────────────────────────
let selectedNutDate = today();

function buildDayStrip() {
  const strip = document.getElementById('nut-day-strip');
  const todayStr = today();

  // Show Mon–Sun of the current week (3 past days + today + 3 future days = full 7-day week)
  const todayDate = new Date();
  const dayOfWeek = todayDate.getDay(); // 0=Sun, 1=Mon...
  // Find Monday of current week
  const monday = new Date(todayDate);
  monday.setDate(todayDate.getDate() - ((dayOfWeek + 6) % 7));

  const days = [];
  for (let i = 0; i < 7; i++) {
    const d = new Date(monday);
    d.setDate(monday.getDate() + i);
    days.push(d.toISOString().slice(0, 10));
  }

  strip.innerHTML = days.map(dateStr => {
    const d = new Date(dateStr + 'T12:00:00');
    const dayName   = d.toLocaleDateString('en-US', { weekday: 'short' });
    const dayNum    = d.getDate();
    const isToday   = dateStr === todayStr;
    const isFuture  = dateStr > todayStr;
    const isSelected = dateStr === selectedNutDate;
    const hasFoods  = (state.foodLog[dateStr] || []).length > 0;
    const totalCal  = (state.foodLog[dateStr] || []).reduce((s,f) => s + (f.cal||0), 0);

    const borderCol  = isSelected ? 'var(--accent)' : isToday ? 'var(--border)' : 'transparent';
    const bgCol      = isSelected ? 'rgba(59,158,255,0.15)' : isToday ? 'var(--surface2)' : 'var(--surface)';
    const labelCol   = isSelected ? 'var(--accent)' : 'var(--muted)';
    const numCol     = isSelected ? 'var(--accent)' : isToday ? 'var(--text)' : isFuture ? 'rgba(255,255,255,0.3)' : 'var(--muted)';
    const dotBg      = hasFoods ? 'var(--accent)' : 'transparent';

    return `<div onclick="selectNutDay('${dateStr}')" style="
      flex:1;
      min-width:0;
      padding:10px 4px 8px;
      border-radius:12px;
      text-align:center;
      cursor:pointer;
      border:1.5px solid ${borderCol};
      background:${bgCol};
      transition:all 0.15s;
    ">
      <div style="font-size:10px;color:${labelCol};text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px">${dayName}</div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;line-height:1;color:${numCol}">${dayNum}</div>
      <div style="margin-top:5px;width:5px;height:5px;border-radius:50%;background:${dotBg};margin-left:auto;margin-right:auto"></div>
      ${hasFoods ? `<div style="font-size:9px;color:var(--muted);margin-top:2px">${Math.round(totalCal)}</div>` : '<div style="height:14px"></div>'}
    </div>`;
  }).join('');

  // Update label
  const sel = new Date(selectedNutDate + 'T12:00:00');
  const isFutureSelected = selectedNutDate > todayStr;
  const label = selectedNutDate === todayStr
    ? 'Today · ' + sel.toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' })
    : (isFutureSelected ? 'Upcoming · ' : '') + sel.toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' });
  document.getElementById('nut-selected-date').textContent = label;

  // Show Add Food button only for today (can't log to future days)
  const addBtn = document.getElementById('nut-add-btn');
  if (addBtn) addBtn.style.display = selectedNutDate === todayStr ? 'inline-block' : 'none';
}

function selectNutDay(dateStr) {
  selectedNutDate = dateStr;
  buildDayStrip();
  refreshNutrition();
}

function openAddFood() {
  document.getElementById('manual-food-name').value = '';
  document.getElementById('manual-cal').value = '';
  document.getElementById('manual-protein').value = '';
  document.getElementById('manual-carbs').value = '';
  document.getElementById('manual-fat').value = '';
  document.getElementById('manual-sodium').value = '';
  document.getElementById('manual-fiber').value = '';
  document.getElementById('manual-sugar').value = '';
  document.getElementById('food-search-input').value = '';
  document.getElementById('food-search-results').innerHTML = '';
  // Reset recipe book section to collapsed
  rbOpen = false;
  document.getElementById('rb-section').style.display = 'none';
  document.getElementById('rb-toggle-btn').textContent = 'Show ▾';
  document.getElementById('rb-search').value = '';
  openModal('add-food-modal');
}

let searchTimer;
function debounceSearch(q) {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => searchFood(q), 500);
}

async function searchFood(query) {
  if (!query.trim()) { document.getElementById('food-search-results').innerHTML = ''; return; }
  const res = document.getElementById('food-search-results');
  res.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:8px">Searching...</div>';
  try {
    const url = `https://world.openfoodfacts.org/cgi/search.pl?search_terms=${encodeURIComponent(query)}&search_simple=1&action=process&json=1&page_size=5`;
    const r = await fetch(url);
    const data = await r.json();
    if (!data.products || !data.products.length) {
      res.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:8px">No results found.</div>';
      return;
    }
    res.innerHTML = data.products.slice(0,5).map((p,i) => {
      const n = p.nutriments || {};
      return `<div onclick='selectSearchResult(${JSON.stringify({
        name: p.product_name || 'Unknown',
        cal: Math.round(n['energy-kcal_100g'] || n['energy-kcal'] || 0),
        protein: +(n.proteins_100g || 0).toFixed(1),
        carbs: +(n.carbohydrates_100g || 0).toFixed(1),
        fat: +(n.fat_100g || 0).toFixed(1),
        sodium: Math.round((n.sodium_100g || 0)*1000),
        fiber: +(n.fiber_100g || 0).toFixed(1),
        sugar: +(n.sugars_100g || 0).toFixed(1),
        calcium: Math.round(n.calcium_100g*1000||0),
        iron: +(n.iron_100g||0).toFixed(2),
        potassium: Math.round(n.potassium_100g*1000||0)
      }).replace(/'/g,"&#39;")})'
        style="padding:10px 0;border-bottom:1px solid var(--border);cursor:pointer">
        <div style="font-size:14px;font-weight:500">${p.product_name || 'Unknown'}</div>
        <div style="font-size:11px;color:var(--muted)">${Math.round(n['energy-kcal_100g']||0)} kcal · P:${+(n.proteins_100g||0).toFixed(1)}g C:${+(n.carbohydrates_100g||0).toFixed(1)}g F:${+(n.fat_100g||0).toFixed(1)}g <span style="color:var(--accent)">(per 100g)</span></div>
      </div>`;
    }).join('');
  } catch(e) {
    res.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:8px">Search failed. Check connection.</div>';
  }
}

function selectSearchResult(food) {
  document.getElementById('manual-food-name').value = food.name;
  document.getElementById('manual-cal').value = food.cal;
  document.getElementById('manual-protein').value = food.protein;
  document.getElementById('manual-carbs').value = food.carbs;
  document.getElementById('manual-fat').value = food.fat;
  document.getElementById('manual-sodium').value = food.sodium || '';
  document.getElementById('manual-fiber').value = food.fiber || '';
  document.getElementById('manual-sugar').value = food.sugar || '';
  document.getElementById('food-search-results').innerHTML = '<div style="color:var(--accent);font-size:12px;padding:4px">✓ Food selected — adjust serving size below</div>';
}

// Derive meal name from current device time
function getMealFromTime() {
  const h = new Date().getHours();
  if (h >= 5  && h < 9)  return 'Breakfast';
  if (h >= 9  && h < 11) return 'Morning Snack';
  if (h >= 11 && h < 14) return 'Lunch';
  if (h >= 14 && h < 17) return 'Afternoon Snack';
  if (h >= 17 && h < 20) return 'Dinner';
  if (h >= 20 && h < 23) return 'Evening Snack';
  return 'Late Night Snack';
}

function addFoodManual(saveToBook = false) {
  const name = document.getElementById('manual-food-name').value.trim();
  if (!name) { showToast('Enter a food name','error'); return; }
  const entry = {
    id: Date.now(),
    name,
    meal: getMealFromTime(),
    cal: parseFloat(document.getElementById('manual-cal').value) || 0,
    protein: parseFloat(document.getElementById('manual-protein').value) || 0,
    carbs: parseFloat(document.getElementById('manual-carbs').value) || 0,
    fat: parseFloat(document.getElementById('manual-fat').value) || 0,
    sodium: parseFloat(document.getElementById('manual-sodium').value) || 0,
    fiber: parseFloat(document.getElementById('manual-fiber').value) || 0,
    sugar: parseFloat(document.getElementById('manual-sugar').value) || 0,
    calcium: parseFloat(document.getElementById('manual-calcium')?.value) || 0,
    iron: parseFloat(document.getElementById('manual-iron')?.value) || 0,
    potassium: parseFloat(document.getElementById('manual-potassium')?.value) || 0,
    vitc: 0, vitd: 0, chol: 0, satfat: 0,
    time: new Date().toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit'})
  };
  const d = today();
  if (!state.foodLog[d]) state.foodLog[d] = [];
  state.foodLog[d].push(entry);

  if (saveToBook) {
    const saved = {
      id: Date.now() + 1,
      name: entry.name,
      cal: entry.cal, protein: entry.protein, carbs: entry.carbs, fat: entry.fat,
      sodium: entry.sodium, fiber: entry.fiber, sugar: entry.sugar,
      savedAt: today()
    };
    if (!state.savedFoods) state.savedFoods = [];
    // avoid exact duplicates by name
    if (!state.savedFoods.find(f => f.name.toLowerCase() === saved.name.toLowerCase())) {
      state.savedFoods.push(saved);
    }
  }

  saveState();
  closeModal('add-food-modal');
  buildDayStrip();
  refreshNutrition();
  refreshDashboard();
  showToast(saveToBook ? 'Logged & saved to Recipe Book! 📖' : 'Food logged!', 'success');
}

function deleteFood(id) {
  state.foodLog[selectedNutDate] = (state.foodLog[selectedNutDate] || []).filter(f => f.id !== id);
  saveState();
  buildDayStrip();
  refreshNutrition();
  refreshDashboard();
  showToast('Removed');
}

function getTodayTotals() {
  return getDayTotals(today());
}

function getDayTotals(dateStr) {
  const foods = state.foodLog[dateStr] || [];
  return foods.reduce((acc, f) => {
    acc.cal += f.cal || 0;
    acc.protein += f.protein || 0;
    acc.carbs += f.carbs || 0;
    acc.fat += f.fat || 0;
    acc.sodium += f.sodium || 0;
    acc.fiber += f.fiber || 0;
    acc.sugar += f.sugar || 0;
    acc.calcium += f.calcium || 0;
    acc.iron += f.iron || 0;
    acc.potassium += f.potassium || 0;
    acc.vitc += f.vitc || 0;
    acc.vitd += f.vitd || 0;
    acc.chol += f.chol || 0;
    acc.satfat += f.satfat || 0;
    return acc;
  }, {cal:0,protein:0,carbs:0,fat:0,sodium:0,fiber:0,sugar:0,calcium:0,iron:0,potassium:0,vitc:0,vitd:0,chol:0,satfat:0});
}

function refreshNutrition() {
  const t = getDayTotals(selectedNutDate);
  const g = state.goals;
  document.getElementById('nut-consumed').textContent = Math.round(t.cal);
  document.getElementById('nut-remaining').textContent = Math.max(0, Math.round(g.calories - t.cal));

  // Macros
  document.getElementById('nut-protein-val').textContent = t.protein.toFixed(0) + 'g';
  document.getElementById('nut-carbs-val').textContent   = t.carbs.toFixed(0) + 'g';
  document.getElementById('nut-fat-val').textContent     = t.fat.toFixed(0) + 'g';
  document.getElementById('nut-bar-protein').style.width = Math.min(100, t.protein / g.protein * 100).toFixed(1) + '%';
  document.getElementById('nut-bar-carbs').style.width   = Math.min(100, t.carbs   / g.carbs   * 100).toFixed(1) + '%';
  document.getElementById('nut-bar-fat').style.width     = Math.min(100, t.fat     / g.fat     * 100).toFixed(1) + '%';
  document.getElementById('nut-bar-protein-lbl').textContent = `${t.protein.toFixed(0)} / ${g.protein}g`;
  document.getElementById('nut-bar-carbs-lbl').textContent   = `${t.carbs.toFixed(0)} / ${g.carbs}g`;
  document.getElementById('nut-bar-fat-lbl').textContent     = `${t.fat.toFixed(0)} / ${g.fat}g`;

  const foods = state.foodLog[selectedNutDate] || [];
  const listEl = document.getElementById('food-log-list');
  const isToday = selectedNutDate === today();

  if (!foods.length) {
    listEl.innerHTML = `<div style="color:var(--muted);font-size:14px;padding:8px 0">${isToday ? 'No foods logged yet.' : 'Nothing logged this day.'}</div>`;
  } else {
    const meals = {};
    foods.forEach(f => { if (!meals[f.meal]) meals[f.meal] = []; meals[f.meal].push(f); });
    listEl.innerHTML = Object.entries(meals).map(([meal, items]) => {
      const mealCal = items.reduce((s,f) => s+f.cal, 0);
      return `<div class="meal-section">
        <div class="meal-header">
          <span class="meal-name">${meal}</span>
          <span class="meal-kcal">${Math.round(mealCal)} kcal</span>
        </div>
        <div class="meal-body">
          ${items.map(f => `
            <div class="food-item">
              <div>
                <div class="food-name">${f.name}</div>
                <div class="food-detail">P:${f.protein.toFixed(1)}g · C:${f.carbs.toFixed(1)}g · F:${f.fat.toFixed(1)}g · ${f.time}</div>
              </div>
              <div style="display:flex;align-items:center;gap:6px">
                <div class="food-cals">${Math.round(f.cal)}</div>
                <button class="del-btn" title="Save to Recipe Book" onclick="saveFoodFromLog(${f.id})" style="color:var(--accent);font-size:14px">🔖</button>
                <button class="del-btn" onclick="deleteFood(${f.id})">✕</button>
              </div>
            </div>`).join('')}
        </div>
      </div>`;
    }).join('');
  }

  const fix = n => n.toFixed(1);
  document.getElementById('mic-sodium').textContent = Math.round(t.sodium) + ' mg';
  document.getElementById('mic-fiber').textContent = fix(t.fiber) + ' g';
  document.getElementById('mic-sugar').textContent = fix(t.sugar) + ' g';
  document.getElementById('mic-calcium').textContent = Math.round(t.calcium) + ' mg';
  document.getElementById('mic-iron').textContent = fix(t.iron) + ' mg';
  document.getElementById('mic-potassium').textContent = Math.round(t.potassium) + ' mg';
  document.getElementById('mic-vitc').textContent = fix(t.vitc) + ' mg';
  document.getElementById('mic-vitd').textContent = Math.round(t.vitd) + ' IU';
  document.getElementById('mic-chol').textContent = Math.round(t.chol) + ' mg';
  document.getElementById('mic-satfat').textContent = fix(t.satfat) + ' g';
}

// ── DASHBOARD ──────────────────────────────────────────────────────────────
function refreshDashboard() {
  const t = getTodayTotals();
  const g = state.goals;
  const remaining = Math.max(0, g.calories - t.cal);

  document.getElementById('cal-remaining-num').textContent = Math.round(remaining);
  document.getElementById('dash-consumed').textContent = Math.round(t.cal);
  document.getElementById('dash-goal').textContent = g.calories;

  const pct = Math.min(1, t.cal / g.calories);
  const circ = 427;
  document.getElementById('cal-ring').style.strokeDashoffset = circ - pct * circ;
  document.getElementById('cal-ring').style.stroke = pct > 1 ? 'var(--accent2)' : 'var(--accent)';

  document.getElementById('dash-protein').textContent = t.protein.toFixed(0) + 'g';
  document.getElementById('dash-carbs').textContent = t.carbs.toFixed(0) + 'g';
  document.getElementById('dash-fat').textContent = t.fat.toFixed(0) + 'g';
  document.getElementById('bar-protein').style.width = Math.min(100, t.protein/g.protein*100).toFixed(1) + '%';
  document.getElementById('bar-carbs').style.width = Math.min(100, t.carbs/g.carbs*100).toFixed(1) + '%';
  document.getElementById('bar-fat').style.width = Math.min(100, t.fat/g.fat*100).toFixed(1) + '%';
  document.getElementById('bar-protein-label').textContent = `${t.protein.toFixed(0)} / ${g.protein}g`;
  document.getElementById('bar-carbs-label').textContent = `${t.carbs.toFixed(0)} / ${g.carbs}g`;
  document.getElementById('bar-fat-label').textContent = `${t.fat.toFixed(0)} / ${g.fat}g`;

  const todayWorkout = state.workoutLog[today()];
  const wSummaryEl = document.getElementById('dash-workout-summary');
  if (todayWorkout && todayWorkout.exercises && todayWorkout.exercises.length) {
    const totalSets = todayWorkout.exercises.reduce((s,e) => s + (e.sets||[]).length, 0);
    wSummaryEl.innerHTML = `<span style="color:var(--green)">✓ ${todayWorkout.exercises.length} exercises · ${totalSets} sets</span>`;
  } else {
    wSummaryEl.innerHTML = `<span style="color:var(--muted)">No workout logged today.</span>`;
  }

  drawMiniWeightChart();
}

