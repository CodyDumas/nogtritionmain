// ── SPLIT CRUD ──
function openNewSplitModal(editId = null) {
  document.getElementById('split-name-input').value = '';
  document.getElementById('split-desc-input').value = '';
  document.getElementById('split-edit-id').value = editId || '';
  document.getElementById('split-modal-title').textContent = editId ? 'Edit Split' : 'New Split';
  if (editId) {
    const s = (state.splits||[]).find(s=>s.id===editId);
    if (s) { document.getElementById('split-name-input').value=s.name; document.getElementById('split-desc-input').value=s.desc||''; }
  }
  openModal('split-modal');
}

function saveSplit() {
  const name = document.getElementById('split-name-input').value.trim();
  if (!name) { showToast('Enter a split name','error'); return; }
  const editId = parseInt(document.getElementById('split-edit-id').value)||null;
  if (!state.splits) state.splits = [];
  if (editId) {
    const s = state.splits.find(s=>s.id===editId);
    if (s) { s.name=name; s.desc=document.getElementById('split-desc-input').value.trim(); }
  } else {
    state.splits.push({ id:Date.now(), name, desc:document.getElementById('split-desc-input').value.trim(), workouts:[] });
  }
  saveState(); closeModal('split-modal'); renderSplitsList();
  showToast(editId ? 'Split updated!' : 'Split created! \ud83d\udcaa', 'success');
}

function deleteSplit(id) {
  if (!confirm('Delete this split and all its workouts?')) return;
  state.splits = (state.splits||[]).filter(s=>s.id!==id);
  saveState(); renderSplitsList();
  showToast('Split deleted');
}

// ── WORKOUTS INSIDE A SPLIT ──
function openSplitWorkouts(splitId) {
  activeSplitId = splitId;
  const s = (state.splits||[]).find(s=>s.id===splitId);
  if (!s) return;
  document.getElementById('wkt-bc-splits').style.display = 'none';
  document.getElementById('wkt-bc-workouts').style.display = 'block';
  document.getElementById('split-workouts-title').textContent = s.name;
  document.getElementById('split-desc-display').textContent = s.desc || '';
  renderWorkoutsInSplit(s);
}

function renderWorkoutsInSplit(s) {
  const el = document.getElementById('split-workouts-list');
  if (!(s.workouts||[]).length) {
    el.innerHTML = '<div style="color:var(--muted);font-size:14px;padding:8px 0">No workouts yet. Tap + Workout to add one.</div>';
    return;
  }
  el.innerHTML = (s.workouts||[]).map(w => `
    <div class="card" style="margin-bottom:10px">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
        <div style="flex:1;min-width:0">
          <div style="font-size:15px;font-weight:500;margin-bottom:2px">${w.name}</div>
          ${w.focus ? `<div style="font-size:12px;color:var(--muted);margin-bottom:8px">${w.focus}</div>` : ''}
          <div style="display:flex;flex-wrap:wrap;gap:5px;margin-top:6px">
            ${(w.exercises||[]).map(ex=>`<span style="background:rgba(59,158,255,0.12);color:var(--accent);font-size:11px;padding:3px 8px;border-radius:6px;white-space:nowrap">${ex.name} <span style="opacity:.6">${ex.muscle}</span></span>`).join('')}
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;flex-shrink:0;margin-left:8px">
          <button class="btn btn-primary btn-sm" onclick="startSessionFromWorkout(${s.id},${w.id})">\u25b6 Start</button>
          <button class="btn btn-secondary btn-sm" onclick="openEditWorkout(${s.id},${w.id})">Edit</button>
