                <div style="font-size:9px;color:var(--muted)">kcal</div>
              </div>
              <div style="text-align:center">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--blue);line-height:1">${totals.protein.toFixed(0)}g</div>
                <div style="font-size:9px;color:var(--muted)">protein</div>
              </div>
              <div style="text-align:center">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--orange);line-height:1">${totals.carbs.toFixed(0)}g</div>
                <div style="font-size:9px;color:var(--muted)">carbs</div>
              </div>
              <div style="text-align:center">
                <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--text);line-height:1">${totals.fat.toFixed(0)}g</div>
                <div style="font-size:9px;color:var(--muted)">fat</div>
              </div>
            </div>
          </div>
          <div style="font-size:20px;flex-shrink:0;margin-top:2px">📖</div>
        </div>
      </div>`;
    }).join('');
