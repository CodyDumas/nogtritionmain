// ── BARCODE SCANNER ────────────────────────────────────────────────────────
let scanStream = null;
async function startBarcodeScanner() {
  closeModal('add-food-modal');
  openModal('barcode-modal');
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
    scanStream = stream;
    const video = document.getElementById('scanner-video');
    video.srcObject = stream;
    document.getElementById('scan-status').textContent = 'Point camera at barcode...';
    if ('BarcodeDetector' in window) {
      const detector = new BarcodeDetector({ formats: ['ean_13','ean_8','upc_a','upc_e','code_128','code_39'] });
      const scanLoop = async () => {
        if (!scanStream) return;
        try {
          const barcodes = await detector.detect(video);
          if (barcodes.length > 0) {
            const barcode = barcodes[0].rawValue;
            document.getElementById('scan-status').textContent = 'Found: ' + barcode + ' — looking up...';
            await lookupBarcode(barcode);
            return;
          }
        } catch {}
        setTimeout(scanLoop, 500);
      };
      await new Promise(r => setTimeout(r, 1500));
      scanLoop();
    } else {
      document.getElementById('scan-status').innerHTML = 'Barcode scanning not supported in this browser.<br><small>Try Chrome on Android. Enter barcode manually below:</small>';
      const barcodeInput = document.createElement('input');
      barcodeInput.type = 'number';
      barcodeInput.placeholder = 'Enter barcode number';
      barcodeInput.style.cssText = 'margin-top:10px;width:100%;background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:10px;padding:10px;font-size:15px;font-family:DM Sans,sans-serif';
      barcodeInput.addEventListener('change', () => lookupBarcode(barcodeInput.value));
      document.getElementById('scan-status').after(barcodeInput);
    }
  } catch(e) {
    document.getElementById('scan-status').textContent = 'Camera access denied. Please allow camera permission.';
  }
}

async function lookupBarcode(barcode) {
  document.getElementById('scan-status').textContent = 'Looking up barcode ' + barcode + '...';
  try {
    const r = await fetch(`https://world.openfoodfacts.org/api/v0/product/${barcode}.json`);
    const data = await r.json();
    if (data.status === 1 && data.product) {
      const p = data.product;
      const n = p.nutriments || {};
      stopScanner();
      openModal('add-food-modal');
      document.getElementById('manual-food-name').value = p.product_name || 'Unknown product';
      document.getElementById('manual-cal').value = Math.round(n['energy-kcal_100g'] || 0);
      document.getElementById('manual-protein').value = (n.proteins_100g || 0).toFixed(1);
      document.getElementById('manual-carbs').value = (n.carbohydrates_100g || 0).toFixed(1);
      document.getElementById('manual-fat').value = (n.fat_100g || 0).toFixed(1);
      document.getElementById('manual-sodium').value = Math.round((n.sodium_100g || 0) * 1000);
      document.getElementById('manual-fiber').value = (n.fiber_100g || 0).toFixed(1);
      document.getElementById('manual-sugar').value = (n.sugars_100g || 0).toFixed(1);
      showToast('✓ Product found! ' + p.product_name?.slice(0,20), 'success');
    } else {
      document.getElementById('scan-status').textContent = 'Product not found. Try scanning again or enter manually.';
    }
  } catch {
    document.getElementById('scan-status').textContent = 'Lookup failed. Check connection.';
  }
}

function stopScanner() {
  if (scanStream) { scanStream.getTracks().forEach(t => t.stop()); scanStream = null; }
  closeModal('barcode-modal');
}

