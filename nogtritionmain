// ── REST TIMER ─────────────────────────────────────────────────────────────
let timerDuration = 120, timerRemaining = 120, timerInterval = null, timerRunning = false;

function showRestTimer() {
  document.getElementById('rest-overlay').classList.add('show');
  setTimer(timerDuration);
  startTimerAuto();
}
function closeTimer() {
  document.getElementById('rest-overlay').classList.remove('show');
  clearInterval(timerInterval); timerRunning = false;
}
function setTimer(secs) {
  clearInterval(timerInterval); timerRunning = false;
  timerDuration = secs; timerRemaining = secs;
  updateTimerDisplay();
  document.getElementById('timer-toggle-btn').textContent = 'Start';
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
}
function startTimerAuto() {
  timerRemaining = timerDuration;
  timerRunning = true;
  document.getElementById('timer-toggle-btn').textContent = 'Pause';
  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    if (!timerRunning) return;
    timerRemaining--;
    updateTimerDisplay();
    if (timerRemaining <= 0) {
      clearInterval(timerInterval); timerRunning = false;
      document.getElementById('timer-toggle-btn').textContent = 'Restart';
      showToast('Rest complete! 🏋️', 'success');
      if ('vibrate' in navigator) navigator.vibrate([200,100,200]);
    }
  }, 1000);
}
function toggleTimer() {
  if (timerRemaining <= 0) { timerRemaining = timerDuration; timerRunning = true; startTimerAuto(); return; }
  timerRunning = !timerRunning;
  document.getElementById('timer-toggle-btn').textContent = timerRunning ? 'Pause' : 'Resume';
  if (timerRunning && !timerInterval) startTimerAuto();
}
function updateTimerDisplay() {
  const m = Math.floor(timerRemaining / 60);
  const s = timerRemaining % 60;
  document.getElementById('timer-display').textContent = `${m}:${String(s).padStart(2,'0')}`;
  const pct = timerRemaining / timerDuration;
  const circ = 553;
  document.getElementById('timer-arc').style.strokeDashoffset = circ * (1 - pct);
  document.getElementById('timer-arc').style.stroke = timerRemaining <= 10 ? 'var(--accent2)' : 'var(--accent)';
}

