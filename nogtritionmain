  });
  const entries = Object.entries(muscleVol).sort((a,b)=>b[1]-a[1]);
  const labels = entries.map(e=>e[0]);
  const vals = entries.map(e=>Math.round(e[1]));

  if (progMuscleChartInst) progMuscleChartInst.destroy();
  const ctx = document.getElementById('prog-muscle-chart').getContext('2d');
  progMuscleChartInst = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{ data: vals, backgroundColor: CHART_COLORS.slice(0,labels.length).map(c=>c+'33'), borderColor: CHART_COLORS.slice(0,labels.length), borderWidth: 1.5, borderRadius: 4 }]
    },
    options: {
      indexAxis: 'y',
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{backgroundColor:'#1e1e1e',borderColor:'#2a2a2a',borderWidth:1,titleColor:'#888',bodyColor:'#f0f0f0'}},
      scales:{
        x:{ticks:{color:'#888',font:{size:9}},grid:{color:'#2a2a2a'},beginAtZero:true},
        y:{ticks:{color:'#f0f0f0',font:{size:11}},grid:{display:false}}
      }
    }
  });
}

function renderPRList(exData) {
  const listEl = document.getElementById('prog-pr-list');
  const entries = Object.values(exData).filter(e=>e.maxWeight.length>0)
    .sort((a,b)=>Math.max(...b.maxWeight)-Math.max(...a.maxWeight));
  if (!entries.length) {
    listEl.innerHTML='<div style="color:var(--muted);font-size:14px;padding:8px 0">Log workouts to see your PRs here.</div>';
    return;
  }
  listEl.innerHTML = entries.map(ex => {
    const prW = Math.max(...ex.maxWeight);
    const prR = Math.max(...ex.maxReps);
    const sessions = ex.dates.length;
    const trend = ex.maxWeight.length >= 2
      ? ex.maxWeight[ex.maxWeight.length-1] > ex.maxWeight[0]
        ? '<span style="color:var(--green);font-size:12px">↑</span>'
        : ex.maxWeight[ex.maxWeight.length-1] < ex.maxWeight[0]
          ? '<span style="color:var(--accent2);font-size:12px">↓</span>'
          : '<span style="color:var(--muted);font-size:12px">→</span>'
      : '';
    return `<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)">
      <div>
        <div style="font-size:14px;font-weight:500">${ex.name} ${trend}</div>
        <div style="font-size:11px;color:var(--muted)">${ex.muscle} · ${sessions} session${sessions!==1?'s':''}</div>
      </div>
      <div style="text-align:right">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--accent);line-height:1">${prW} lbs</div>
        <div style="font-size:10px;color:var(--muted)">${prR} reps max</div>
      </div>
    </div>`;
  }).join('');
}

function getWeekLabel(d) {
  const day = d.getDay();
  const diff = d.getDate() - day + (day===0?-6:1);
  const mon = new Date(d.setDate(diff));
  return mon.toISOString().slice(5,10);
}

