function renderRecipeIngredients() {
  const list = document.getElementById('recipe-ingredients-list');
  const empty = document.getElementById('recipe-ing-empty');
  const totalsBar = document.getElementById('recipe-totals-bar');

  if (!currentRecipeIngredients.length) {
    list.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:6px 0" id="recipe-ing-empty">No ingredients yet.</div>';
    totalsBar.style.display = 'none';
    return;
  }
  totalsBar.style.display = 'block';
  list.innerHTML = currentRecipeIngredients.map((ing, i) => `
    <div style="display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--border)">
      <div style="flex:1;min-width:0">
        <div style="font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${ing.name}</div>
        <div style="font-size:11px;color:var(--muted)">${Math.round(ing.cal * ing.servings)} kcal · ×${ing.servings} serving${ing.servings!==1?'s':''}</div>
      </div>
      <div style="display:flex;align-items:center;gap:6px;flex-shrink:0">
        <button onclick="changeServing(${i},-1)" style="background:var(--surface2);border:1px solid var(--border);color:var(--text);width:28px;height:28px;border-radius:8px;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center">−</button>
        <span style="font-size:14px;min-width:16px;text-align:center">${ing.servings}</span>
        <button onclick="changeServing(${i},1)" style="background:var(--surface2);border:1px solid var(--border);color:var(--accent);width:28px;height:28px;border-radius:8px;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center">+</button>
        <button class="del-btn" onclick="removeIngredient(${i})" style="font-size:14px">✕</button>
      </div>
    </div>`).join('');

  // Update totals
  const t = currentRecipeIngredients.reduce((acc,ing)=>{
    const s=ing.servings||1;
    acc.cal+=(ing.cal||0)*s; acc.protein+=(ing.protein||0)*s;
    acc.carbs+=(ing.carbs||0)*s; acc.fat+=(ing.fat||0)*s; return acc;
  },{cal:0,protein:0,carbs:0,fat:0});
  document.getElementById('rtotal-cal').textContent = Math.round(t.cal);
  document.getElementById('rtotal-protein').textContent = t.protein.toFixed(0)+'g';
  document.getElementById('rtotal-carbs').textContent = t.carbs.toFixed(0)+'g';
  document.getElementById('rtotal-fat').textContent = t.fat.toFixed(0)+'g';
}

function changeServing(idx, delta) {
  currentRecipeIngredients[idx].servings = Math.max(0.5, (currentRecipeIngredients[idx].servings||1) + delta);
  renderRecipeIngredients();
}

function removeIngredient(idx) {
  currentRecipeIngredients.splice(idx, 1);
  renderRecipeIngredients();
}

function openPickIngredient() {
