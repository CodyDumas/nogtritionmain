// ── GOOGLE SHEETS SYNC ─────────────────────────────────────────────────────
async function syncToSheets() {
  const { id, key } = state.sheets;
  if (!id || !key) {
    showToast('Set Sheet ID & API key first','error');
    navTo('settings', document.querySelectorAll('.tab')[4]);
    return;
  }
  document.getElementById('sheets-status').textContent = 'Syncing...';
  try {
    const rows = [];
    // Food log rows
    Object.entries(state.foodLog).forEach(([date, foods]) => {
      foods.forEach(f => {
        rows.push([date, 'food', f.meal, f.name, f.cal, f.protein, f.carbs, f.fat, f.sodium, f.fiber, f.sugar]);
      });
    });
    // Weight rows
    state.weightLog.forEach(w => rows.push([w.date, 'weight', '', '', w.weight, '', '', '', '', '', w.note||'']));
    // Workout rows
    Object.entries(state.workoutLog).forEach(([date, w]) => {
      (w.exercises||[]).forEach(ex => {
        (ex.sets||[]).forEach((s, si) => {
          rows.push([date, 'workout', ex.muscle, ex.name, s.weight, s.reps, '', '', si+1, '', s.notes||'']);
        });
      });
    });

    const range = 'Sheet1!A1';
    const values = [
      ['Date','Type','Category','Name','Value1','Value2','Value3','Value4','Value5','Value6','Notes'],
      ...rows
    ];
    const url = `https://sheets.googleapis.com/v4/spreadsheets/${id}/values/${range}?valueInputOption=RAW&key=${key}`;
    const resp = await fetch(url.replace('?', '?'), {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ values })
    });

    if (resp.ok) {
      document.getElementById('sheets-status').textContent = '✓ Synced ' + rows.length + ' rows — ' + new Date().toLocaleTimeString();
      showToast('Synced to Google Sheets!', 'success');
    } else {
      const err = await resp.json();
      document.getElementById('sheets-status').textContent = '✗ Error: ' + (err.error?.message || 'Unknown error');
      showToast('Sync failed','error');
    }
  } catch(e) {
    document.getElementById('sheets-status').textContent = '✗ Network error';
    showToast('Sync failed: ' + e.message, 'error');
  }
}

